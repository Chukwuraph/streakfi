# Torque Protocol integration
# Create an API key via the Torque MCP `create_api_key` tool or the platform.torque.so dashboard
TORQUE_API_KEY=
TORQUE_INGEST_URL=https://ingest.torque.so/events
TORQUE_API_BASE=https://api.torque.so

# StreakFi configuration
STREAKFI_EVENT_NAME=streak_maintained
STREAKFI_BROKEN_EVENT_NAME=streak_broken
STREAKFI_SHARED_EVENT_NAME=streak_shared
STREAKFI_REFERRAL_EVENT_NAME=referral_converted

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_APP_URL=http://localhost:3000
